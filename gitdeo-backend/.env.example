# Copy this file to .env and fill in your real values.
# Get GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET from:
# https://github.com/settings/developers -> your GitDeo OAuth App

# Only needed if ffmpeg isn't on your system PATH (common on Windows).
# Set this to the full path to ffmpeg.exe, e.g.:
# FFMPEG_PATH=C:\ffmpeg\ffmpeg-8.1.2-essentials_build\bin\ffmpeg.exe
FFMPEG_PATH=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Only change these if you're running on different ports/hosts
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Change this to a long random string before you ever deploy this publicly
GITDEO_SECRET_KEY=dev-secret-change-this-before-deploy
